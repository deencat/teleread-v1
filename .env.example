# OpenRouter credentials
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Comma-separated browser-use models exposed in your OpenRouter account
BROWSER_USE_MODELS=openai/gpt-4o-mini,openai/gpt-4.1-mini,anthropic/claude-3.5-sonnet

# Optional default model (must be one item from BROWSER_USE_MODELS)
BROWSER_USE_DEFAULT_MODEL=openai/gpt-4o-mini

# Optional max browser-use steps
BROWSER_USE_MAX_STEPS=30

# Optional vision toggle for browser-use (true/false).
# Keep false for text-only models on OpenRouter.
BROWSER_USE_USE_VISION=false

# Optional: attach to an already-running Chrome via CDP
# Example:
# BROWSER_USE_CDP_URL=http://127.0.0.1:9222
BROWSER_USE_CDP_URL=

# Fallback chat row index in left chat list (0-based).
# 2 means "third item", matching your current Telegram layout.
BROWSER_USE_FALLBACK_CHAT_INDEX=2
